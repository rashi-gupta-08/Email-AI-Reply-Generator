{
  "name": "Email Writer Assistant",
  "description": "AI- powered email reply generator",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab", "storage"],
  "host_permissions": [
      "https://localhost:8081/*",
      "*://mail.google.com/*"  
    ],
  "content_scripts": [
      {
        "matches": ["*://mail.google.com/*"],
        "js": ["content.js"],
        "css": ["content.css"],
        "run_at": "document_end"
      }
    ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["*://mail.google.com/*"]
    }
  ],
  "action": {
    "default_title": "Email Writer Assistant"
    
  }
}